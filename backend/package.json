    "@fastify/multipart": "^9.2.1",
    "@fastify/websocket": "^11.2.0",
    "ai": "^6.0.70",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1",
    "pg": "^8.16.3",
    "pg-boss": "^12.3.0",
    "zod": "^4.3.6",
    "@ai-transcript/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
