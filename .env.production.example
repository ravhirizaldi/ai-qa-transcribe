# Runtime
NODE_ENV=production
PORT=3001
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGIN=http://localhost
UPLOAD_DIR=/app/backend/uploads
USE_DOCKER_POSTGRES=true

# Postgres
POSTGRES_DB=ai_transcript
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgres://postgres:change-this-postgres-password@db:5432/ai_transcript
# If USE_DOCKER_POSTGRES=false and Postgres runs on the same Linux host,
# use host.docker.internal instead of localhost, for example:
# DATABASE_URL=postgres://postgres:password@host.docker.internal:5432/ai_transcript

# Public app
PUBLIC_APP_PORT=80
BACKEND_HTTP_UPSTREAM=http://backend:3001
BACKEND_WS_UPSTREAM=http://backend:3001/ws

# Optional provider fallback values for the worker/backend
ELEVENLABS_API_KEY=
XAI_API_KEY=
XAI_MODEL=grok-4-1-fast-non-reasoning
XAI_MANAGEMENT_API_KEY=
XAI_RAG_MODEL=grok-4-1-fast-reasoning

# Optional worker tuning
WORKER_PROVIDER_CACHE_TTL_MS=30000
WORKER_POLLING_INTERVAL_SECONDS=2
WORKER_TRANSCRIBE_BATCH_SIZE=1
WORKER_ANALYZE_BATCH_SIZE=1
WORKER_FINALIZE_BATCH_SIZE=5
WORKER_RAG_BATCH_SIZE=5
WORKER_TRANSCRIBE_LOCAL_CONCURRENCY=2
WORKER_ANALYZE_LOCAL_CONCURRENCY=2
WORKER_FINALIZE_LOCAL_CONCURRENCY=2
WORKER_RAG_LOCAL_CONCURRENCY=1

# Optional DB wait tuning for migrations
DB_WAIT_MAX_ATTEMPTS=30
DB_WAIT_INTERVAL_SECONDS=3
REMOVE_MIGRATE_IMAGE_AFTER_RUN=true
